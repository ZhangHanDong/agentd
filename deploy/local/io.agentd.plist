<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>io.agentd</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/agentd</string>
    <string>--security-mode</string>
    <string>standalone</string>
    <string>--db-path</string>
    <string>/Users/Shared/agentd/agentd.db</string>
    <string>--repo-dir</string>
    <string>/Users/Shared/agentd/repository</string>
    <string>--worktree-base</string>
    <string>/Users/Shared/agentd/worktrees</string>
    <string>--workflows-dir</string>
    <string>/Users/Shared/agentd/workflows</string>
    <string>--port</string>
    <string>8787</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>AGENTD_NATIVE_RUNTIME</key>
    <string>1</string>
    <key>RUST_LOG</key>
    <string>agentd=info</string>
  </dict>
  <key>WorkingDirectory</key>
  <string>/Users/Shared/agentd</string>
  <key>StandardOutPath</key>
  <string>/Users/Shared/agentd/log/agentd.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/Shared/agentd/log/agentd.err.log</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>
  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
