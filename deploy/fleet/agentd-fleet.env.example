# Non-secret fleet handoff contract. Supply credentials through the workload
# identity and secret-broker integrations, never through this file.
AGENTD_NATIVE_RUNTIME=1
AGENTD_WORKER_DISPATCH=pull
AGENTD_IMAGE_POLICY=immutable-digest
AGENTD_WORKER_PROTOCOL_VERSION=1
AGENTD_CONTROL_PLANE_URL=https://agentd.example.invalid
AGENTD_TRUST_DOMAIN=example.invalid
AGENTD_REGION=replace-me
AGENTD_ZONE=replace-me
AGENTD_WORKER_POOL=replace-me
AGENTD_CAPACITY_CLASS=general
AGENTD_DATA_CLASSIFICATION=internal
